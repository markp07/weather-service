{
  "policyVersion": "1.0.0",
  "versioning": {
    "scheme": "semver",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
    "example": "1.0.0"
  },
  "accessControl": {
    "denyPathPatterns": [
      "^\\.env(\\..*)?$"
    ],
    "allowPathPatterns": [
      "^\\.env\\.example$"
    ],
    "securityRules": [
      "neverCommitSecretsOrPrivateKeys",
      "neverLogTokensOrCredentials",
      "doNotWeakenAuthByDefault"
    ],
    "generatedPathsReadOnly": [
      "^.*/target/.*$",
      "^.*/\\.next/.*$",
      "^.*/coverage/.*$"
    ]
  },
  "branching": {
    "allowedPrefixes": [
      "major",
      "feature",
      "fix"
    ],
    "branchNamePattern": "^(major|feature|fix)\\/[a-z0-9][a-z0-9-]*$",
    "releaseIntentMapping": {
      "major": "major",
      "feature": "minor",
      "fix": "patch"
    },
    "optionalBackwardCompatNoteFor": "bugfix/*"
  },
  "commitMessageFramework": {
    "standard": "conventional-commits",
    "allowedTypes": [
      "feat",
      "fix",
      "docs",
      "refactor",
      "test",
      "chore",
      "build",
      "ci",
      "perf",
      "revert"
    ],
    "headerPattern": "^(feat|fix|docs|refactor|test|chore|build|ci|perf|revert)(\\([a-z0-9-]+\\))?(!)?: [^\\s].*[^\\.]$",
    "breakingChangeFooter": "BREAKING CHANGE:"
  },
  "responseContract": {
    "sectionsInOrder": [
      "Plan",
      "Changes",
      "Validation",
      "Risks/Assumptions",
      "Next Steps"
    ],
    "orderEnforced": true
  }
}
