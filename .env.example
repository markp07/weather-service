# Postgres Database Configuration
POSTGRES_PASSWORD=your_postgres_password_here

# JWT Configuration
JWT_PUBLIC_KEY_URL=https://auth.markpost.dev/api/auth/v1/public-key

# CORS Configuration
ALLOWED_ORIGIN_PATTERNS=https://weather.markpost.dev

# Frontend Configuration
NEXT_PUBLIC_AUTH_API_URL=https://auth.markpost.dev
NEXT_PUBLIC_WEATHER_API_URL=https://weather.markpost.dev

# Reverse Geocoding API Configuration
# Get your API key from https://api-bdc.io
REVERSE_GEOCODE_API_KEY=your_reverse_geocode_api_key_here

# MeteoGate Weather Alarms API Configuration
# Get your API key (Bearer token) from https://api.meteogate.eu
METEOALARM_API_KEY=your_meteogate_api_key_here

