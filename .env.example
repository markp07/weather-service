# ===========================================
# Weather Service Environment Configuration
# ===========================================
# Copy this file to .env and configure with your actual values
# NEVER commit the .env file to version control!

# Database Configuration
# PostgreSQL password for the weather_service database
# REQUIRED: Set a strong password for production
POSTGRES_PASSWORD=your_secure_postgres_password

# Optional: External Authentication Service URLs
# Configure these if deploying to production
# Default development URLs point to localhost:3000 for auth service
# NEXT_PUBLIC_AUTH_API_URL=https://your-auth-service.com
# NEXT_PUBLIC_WEATHER_API_URL=https://your-weather-api.com

