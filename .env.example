# ===========================================
# Weather Service Environment Configuration
# ===========================================
# Copy this file to .env and configure with your actual values
# NEVER commit the .env file to version control!

# Database Configuration
# PostgreSQL password for the weather_service database
# REQUIRED: Set a strong password for production
POSTGRES_PASSWORD=your_secure_postgres_password

# JWT Authentication Configuration
# URL to fetch the public key from the authentication service
# This service works with https://github.com/markp07/authentication-service
# For local development: http://localhost:3000/api/auth/v1/public-key
# For production: https://your-auth-service.com/api/auth/v1/public-key
JWT_PUBLIC_KEY_URL=http://localhost:3000/api/auth/v1/public-key

# CORS Configuration
# Comma-separated list of allowed origin patterns for CORS
# For local development: http://localhost:3030
# For production: https://your-frontend-domain.com
ALLOWED_ORIGIN_PATTERNS=http://localhost:3030

# Frontend Service URLs (Optional for production)
# These are used by the Next.js frontend for API calls
# For local development, the frontend auto-detects localhost
# For production, configure your actual service URLs
NEXT_PUBLIC_AUTH_API_URL=https://auth.yourdomain.com
NEXT_PUBLIC_WEATHER_API_URL=https://weather.yourdomain.com

